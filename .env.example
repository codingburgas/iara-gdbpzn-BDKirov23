# ====================================
# ГДПБЗН Emergency Response System
# AI Provider Configuration
# ====================================
# 
# Choose ONE provider below.
# Uncomment and set the API key for your preferred provider.
# If none are set, the system uses the built-in rule-based AI.
# 
# ====================================

# Option 1: Google Gemini (RECOMMENDED - Free tier available)
# Get a free API key at: https://aistudio.google.com/apikey
# The free tier allows 60 requests per minute, completely free.
# GEMINI_API_KEY=your_gemini_api_key_here

# Option 2: Together AI
# Get an API key at: https://api.together.xyz/settings/api-keys
# They offer free credits for new users.
# TOGETHER_API_KEY=your_together_api_key_here

# ====================================
# Server Configuration
# ====================================
# SECRET_KEY=gdpbzn-secret-key-change-in-production
# JWT_SECRET_KEY=jwt-secret-key-change
